# 이어서 server 환경변수 템플릿
# 복사: cp server/.env.example server/.env  (server/.env 는 커밋되지 않음)
# application.yaml 의 spring.config.import 가 server 작업 디렉터리의 .env 를 로드한다.
# CI/운영은 이 파일 대신 실제 OS 환경변수를 주입한다(우선순위 더 높음).
# 실제 시크릿을 이 파일(.env.example)에 절대 넣지 말 것 — 플레이스홀더만.

# ── DB (PostgreSQL) ───────────────────────────────────────
# docker-compose(db)와 Spring datasource가 같은 값을 공유한다.
# DB_PASSWORD 는 로컬 개발 기본값(ieoseo) — 운영은 반드시 교체.
DB_URL=jdbc:postgresql://localhost:5432/ieoseo
DB_USERNAME=ieoseo
DB_PASSWORD=ieoseo
POSTGRES_DB=ieoseo
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── 앱 ────────────────────────────────────────────────────
SERVER_PORT=8080
IEOSEO_MAX_DAILY_MINUTES=480

# ── JWT (인증 토큰) ───────────────────────────────────────
# 운영은 32바이트+ 무작위. 외부 노출 금지. 생성: openssl rand -hex 32
# ⚠️ 비워두면(JWT_SECRET=) "빈 시크릿"으로 덮어써져 기동 실패한다. 로컬은 아래처럼
#    주석 유지(미설정 → application.yaml 의 dev 임시 기본값으로 기동). 운영은 실제 값 주입.
#JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=1209600
# refresh 저장소: redis | (미설정=in-memory 폴백, 단일 인스턴스 한정)
JWT_REFRESH_STORE=

# ── 소셜 OAuth (서버측 검증 — ID token aud / 앱 식별) ─────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
KAKAO_CLIENT_ID=

# ── 관측성 (Sentry) ───────────────────────────────────────
# SENTRY_DSN 미설정(빈 값)이면 Sentry 비활성 — 외부 전송 0. 키 넣으면 즉시 활성.
# DSN 은 시크릿 — 이 파일(.env.example)엔 절대 넣지 말 것(.env 에만).
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
# 성능 트레이스 샘플링 0.0~1.0 (0.0=에러만). 운영 권장 0.1 안팎.
SENTRY_TRACES_SAMPLE_RATE=0.0
